# ==============================================================================
# OMV 私有配置模板 (private.env.example)
# ==============================================================================
# 使用方式：
#   cp private.env.example secrets/private.env
#   然后在 secrets/private.env 中填入你自己的实际值
#
# 此模板列出所有需要自定义的私有配置项，对应 global.env 中的 <占位符>。
# secrets/private.env 已被 .gitignore 忽略，不会被提交。
# ==============================================================================

# ─── Immich ───────────────────────────────────────────────────────────────────
# PostgreSQL 数据库密码，首次部署时自定义，之后不可更改
IMMICH_DB_PASSWORD=

# ─── Cloudflare 认证 ──────────────────────────────────────────────────────────
# 在 Cloudflare Zero Trust 控制台 → Tunnels 中获取 Token
CF_TUNNEL_TOKEN=

# ─── Servarr ──────────────────────────────────────────────────────────────────
# Servarr 统一认证密码，用于 Sonarr/Radarr/Whisparr 登录认证
SERVARR_TARGET_PASS=
# qBittorrent Web UI 密码
SERVARR_QB_PASS=

# ─── Jellyfin ─────────────────────────────────────────────────────────────────
# Jellyfin 管理员账户凭据，用于 Jellyseerr 初始化
SERVARR_JELLYFIN_USER=
SERVARR_JELLYFIN_PASS=
SERVARR_JELLYFIN_EMAIL=
SERVARR_JELLYFIN_BASE_URL=