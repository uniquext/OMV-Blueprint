# ==============================================================================
# Tailscale 局部环境变量配置
# ==============================================================================

# Tailscale 认证密钥
# 从 Tailscale 管理控制台获取：https://login.tailscale.com/admin/settings/keys
# 建议使用 Reusable + Pre-approved 类型的 key，适合长期运行的服务器
AUTH_KEY=${TAILSCALE_AUTHKEY}
