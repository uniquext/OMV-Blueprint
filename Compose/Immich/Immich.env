# ==============================================================================
# Immich 局部环境变量配置 (基于官方标准 v2)
# ==============================================================================

# 1. 数据库凭据 (本地隔离)
IMMICH_DB_PASSWORD=<Immich数据库密码>
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# 2. 核心路径配置 (由 YML 引用)
DB_DATA_LOCATION=./data
# 核心相册上传路径 (引用 global.env 中的 PHOTO_PATH)
UPLOAD_LOCATION=${PHOTO_PATH}
# 服务主机名 (用于多容器间互通讯)
SERVER_HOSTNAME=immich-server
ML_HOSTNAME=immich-machine-learning
DB_HOSTNAME=immich-postgres
REDIS_HOSTNAME=immich-redis

# 3. 版本控制与安全
IMMICH_VERSION=v2.6.3

# 4. 代理信任配置 (修复 Cloudflare Access/CSRF 登录问题)
# 包含 127.0.0.1, ::1 (用于隧道本地转发) 及您的局域网段。
IMMICH_TRUSTED_PROXIES=127.0.0.1, ::1, 192.168.1.0/24
