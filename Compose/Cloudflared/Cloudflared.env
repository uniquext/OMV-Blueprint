# ==============================================================================
# Cloudflared 局部环境变量配置
# ==============================================================================

# Cloudflare Tunnel 认证令牌
# 从 Cloudflare Zero Trust Dashboard 获取：https://one.dash.cloudflare.com/
# 路径：Networks -> Tunnels -> Create a tunnel -> Choose your tunnel type -> Cloudflared
CF_TUNNEL_TOKEN=<your-tunnel-token-here>
