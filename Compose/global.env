# ==============================================================================
# OMV 全局环境变量配置 (global.env)
# ==============================================================================
# 此文件被 OMV Compose 插件全局加载，适用于所有服务。
# 敏感或私有路径以 <占位符> 标注，请参考 private.env.example 创建
# secrets/private.env，并将实际值填入 OMV Web UI 的全局环境变量配置框。
# ==============================================================================

# 1. 运行用户与权限控制
PUID=<appuser_uid>                      # 容器运行用户的 UID (对应 OMV 中的 appuser)
PGID=<appuser_gid>                      # 容器运行用户的 GID (对应 users 组)

# 2. 系统环境与时区
TZ=Asia/Shanghai                       # 容器内时区设置，确保日志与任务计划时间准确
