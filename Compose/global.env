# ==============================================================================
# OMV 全局环境变量配置 (global.env)
# ==============================================================================
# 此文件由 OMV Compose 插件全局加载，定义各容器通用的核心路径与运行参数。
# ==============================================================================

# 1. 基础设施与权限 (Infrastructure & Permissions)
# ------------------------------------------------------------------------------
PUID=1001                              # 容器运行用户的 UID (对应 OMV 中的 appuser)
PGID=100                               # 容器运行用户的 GID (对应 users 组)
TZ=Asia/Shanghai                       # 容器全局时区设置，确保日志与定时任务时间同步

# 宿主机时区与本地时间文件路径 (供 YML 中的 volumes 进行映射)
LOCALTIME_PATH=/etc/localtime          # 宿主机本地时间定义文件

# 2. 公共资源层 (AppData - Shared Configuration)
# ------------------------------------------------------------------------------
# 存放多个服务共用的静态资源、共享脚本、以及可复用的配置模板。
COMPOSE_DATA_PATH=/srv/dev-disk-by-uuid-796be7e9-7323-4320-81ff-f454046e5c00/AppData

# 共享资源详细子路径
NVIDIA_GPU_TEMPLATE=${COMPOSE_DATA_PATH}/template/gpu-template.yml # 全局 GPU 复用配置模板

# 3. 媒体资源层 (Resource - Massive Storage)
# ------------------------------------------------------------------------------
# 对应 OMV 中挂载的海量存储分区路径。
RESOURCE=/srv/dev-disk-by-uuid-da0330ea-1149-4578-a53a-b4faae222a9f

# 基于 RESOURCE 自动组合的业务路径 (无需手动硬编码子目录)
PHOTO_PATH=${RESOURCE}/DCIM                 # 全局相册与 Immich 数据的存储根目录
PHOTO_EXTERNAL_LIBRARY=${RESOURCE}/Photo    # Immich 外部库
CLOUD_PATH=${RESOURCE}/Cloud                # 个人网盘/同步文件的存储根目录

# 4. 硬件加速 (Hardware Acceleration)
# ------------------------------------------------------------------------------
# 集成显卡 (VAAPI/QuickSync) 路径
DRI=/dev/dri                           # Intel/AMD 核显设备文件路径

# NVIDIA 独显 (Container Toolkit) 配置
NVIDIA_VISIBLE_DEVICES=all             # 指定容器可见的 NVIDIA GPU 设备 (all 表示全部)
NVIDIA_DRIVER_CAPABILITIES=compute,video,utility # 指定 GPU 驱动能力 (转码、计算、工具支持)