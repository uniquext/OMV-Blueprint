# ==============================================================================
# Servarr 局部环境变量配置
# ==============================================================================

# 1. 统一认证凭据
TARGET_USER=admin
TARGET_PASS=${SERVARR_TARGET_PASS}
QB_PASS=${SERVARR_QB_PASS}

JELLYFIN_USER=${SERVARR_JELLYFIN_USER}
JELLYFIN_PASS=${SERVARR_JELLYFIN_PASS}
JELLYFIN_EMAIL=${SERVARR_JELLYFIN_EMAIL}
JELLYFIN_BASE_URL=${SERVARR_JELLYFIN_BASE_URL}

ST_LLM_API_URL=${SERVARR_LLM_API_URL}
ST_LLM_API_KEY=${SERVARR_LLM_API_KEY}
ST_LLM_MODEL=${SERVARR_LLM_MODEL}
ST_LLM_MODEL_TYPE=${SERVARR_LLM_MODEL_TYPE}

# 2. 服务发现 (Hostnames)
FLARESOLVERR_HOSTNAME=flaresolverr
PROWLARR_HOSTNAME=prowlarr
QBITTORRENT_HOSTNAME=qbittorrent
SONARR_HOSTNAME=sonarr
RADARR_HOSTNAME=radarr
WHISPARR_HOSTNAME=whisparr
BAZARR_HOSTNAME=bazarr
JELLYSEERR_HOSTNAME=jellyseerr
RECYCLARR_HOSTNAME=recyclarr
QBITRR_HOSTNAME=qbitrr
SUBTITLE_TRANSLATOR_HOSTNAME=subtitle-translator

# 3. 端口配置
FLARESOLVERR_PORT=8191
QBITTORRENT_PORT=8082
QBITTORRENT_BT_PORT=6881
PROWLARR_PORT=9696
SONARR_PORT=8989
RADARR_PORT=7878
WHISPARR_PORT=6969
BAZARR_PORT=6767
JELLYSEERR_PORT=5055
QBITRR_PORT=6970
SUBTITLE_TRANSLATOR_PORT=9800

# 4. 代理排除 (NO_PROXY 扩展)
# 确保 Prowlarr 等服务在访问内网容器时不经过代理，避免 502 Bad Gateway
SERVARR_NO_PROXY=${NO_PROXY},${FLARESOLVERR_HOSTNAME},${PROWLARR_HOSTNAME},${QBITTORRENT_HOSTNAME},${SONARR_HOSTNAME},${RADARR_HOSTNAME},${WHISPARR_HOSTNAME},${BAZARR_HOSTNAME},${JELLYSEERR_HOSTNAME},${RECYCLARR_HOSTNAME},${QBITRR_HOSTNAME},${SUBTITLE_TRANSLATOR_HOSTNAME}
